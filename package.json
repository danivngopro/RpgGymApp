{
  "name": "rpg-gym-app",
  "private": true,
  "version": "0.1.0",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev": "npm run dev -w @rpg-gym/api",
    "dev:web": "npm run dev -w @rpg-gym/web",
    "build": "npm run build --workspaces",
    "test": "npm run test -w @rpg-gym/api",
    "lint": "npm run lint --workspaces",
    "db:migrate": "dotenv -e .env -- prisma migrate dev --schema apps/api/prisma/schema.prisma",
    "db:seed": "dotenv -e .env -- tsx apps/api/prisma/seed.ts"
  },
  "devDependencies": {
    "dotenv-cli": "^7.4.2",
    "typescript": "^5.5.4"
  }
}
